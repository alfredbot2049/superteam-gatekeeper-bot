# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Group IDs (get via @getidsbot or similar)
PUBLIC_GROUP_ID=-100xxxxxxxxxx
MEMBER_CIRCLE_ID=-100xxxxxxxxxx

# Comma-separated Telegram user IDs of admins
ADMIN_IDS=123456789,987654321

# Luma Calendar ID
LUMA_CALENDAR_ID=mysuperteam
